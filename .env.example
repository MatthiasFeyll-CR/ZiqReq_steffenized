AZURE_OPENAI_DEFAULT_DEPLOYMENT=
AZURE_OPENAI_CHEAP_DEPLOYMENT=
AZURE_OPENAI_ESCALATED_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# gRPC addresses
CORE_GRPC_ADDRESS=core:50051
AI_GRPC_ADDRESS=ai:50052
PDF_GRPC_ADDRESS=pdf:50053
GATEWAY_GRPC_ADDRESS=gateway:50054

# Notification service (Azure Communication Services Email)
ACS_EMAIL_ENDPOINT=
ACS_EMAIL_ACCESS_KEY=
EMAIL_FROM=DoNotReply@<your-azure-managed-domain>

# PDF storage
PDF_STORAGE_PATH=/data/pdfs
AZURE_STORAGE_CONNECTION_STRING=

# Frontend (build-time)
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=/ws
VITE_AZURE_AD_CLIENT_ID=
VITE_AZURE_AD_TENANT_ID=
