# Django
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,gateway,core,ai,nginx
DEBUG=True

# Auth bypass (local development only)
AUTH_BYPASS=True

# Azure AD
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
