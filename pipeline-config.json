  ],
  "models": {
    "ralph": "claude-opus-4-6",
    "phase0": "claude-opus-4-6",
    "prd_generation": "claude-sonnet-4-5",
    "qa_review": "claude-opus-4-6",
    "test_fix": "claude-sonnet-4-5",
    "gate_fix": "claude-opus-4-6",
    "reconciliation": "claude-sonnet-4-5"
  },
  "ralph": {
    "tool": "claude",
    "max_iterations_multiplier": 3,
    "stuck_threshold": 3
  },
  "qa": {
    "max_bugfix_cycles": 3
  },
  "gate_checks": {
    "max_fix_cycles": 3,
    "checks": [
      {
        "name": "Docker build",
        "command": "docker compose build",
        "condition": "command -v docker && test -f docker-compose.yml",
        "required": true
      },
      {
        "name": "Frontend typecheck",
        "command": "cd frontend && npx tsc --noEmit",
        "condition": "test -f frontend/tsconfig.json",
        "required": true
      },
      {
        "name": "Backend lint (Ruff)",
        "command": "ruff check services/",
        "condition": "test -d services && command -v ruff",
        "required": true
      },
      {
        "name": "Backend typecheck (mypy)",
        "command": "mypy services/",
        "condition": "test -d services && command -v mypy",
        "required": false
      },
      {
        "name": "Frontend lint (ESLint)",
        "command": "cd frontend && npx eslint src/",
        "condition": "test -f frontend/eslint.config.js",
        "required": false
      }
    ]
  },
  "env_setup": {
    "source_file": null,
    "setup_function": null,
    "description": "All environment configuration handled via .env file (ports, API keys, Azure credentials)."
  },
  "retry": {
    "max_retries": 3,
    "backoff_seconds": 30
  },
  "cost": {
    "budget_usd": 750
  },
  "test_execution": {
    "test_command": "docker compose -f docker-compose.test.yml run --rm python-tests pytest",
    "integration_test_command": "docker compose -f docker-compose.test.yml run --rm node-tests npx vitest run",
    "setup_command": "docker compose -f docker-compose.test.yml up -d --build",
    "teardown_command": "docker compose -f docker-compose.test.yml down",
    "force_teardown_command": "docker compose -f docker-compose.test.yml down -v --remove-orphans",
    "build_command": "docker compose -f docker-compose.test.yml build",
    "condition": "command -v docker",
    "setup_timeout_seconds": 120,
    "timeout_seconds": 600,
    "build_timeout_seconds": 300,
    "tier1": {
      "compose_file": "docker-compose.test.yml",
      "environments": [
        {
          "name": "python",
          "service": "python",
          "test_command": "docker compose -f docker-compose.test.yml run --rm python-tests pytest",
          "timeout_seconds": 600
        },
        {
          "name": "node",
          "service": "node",
          "test_command": "docker compose -f docker-compose.test.yml run --rm node-tests npx vitest run",
          "timeout_seconds": 600
        }
      ]
    },
    "services": [
      {
        "name": "postgres",
        "type": "tcp",
        "host": "localhost",
        "port": 5432,
        "startup_timeout": 120
      },
      {
        "name": "redis",
        "type": "tcp",
        "host": "localhost",
        "port": 6379,
        "startup_timeout": 120
      },
      {
        "name": "rabbitmq",
        "type": "tcp",
        "host": "localhost",
        "port": 5672,
        "startup_timeout": 120
      }
    ]
  }
}
