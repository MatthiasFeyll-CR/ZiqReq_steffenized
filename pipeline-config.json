  "models": {
    "ralph": "claude-opus-4-6",
    "phase0": "claude-opus-4-6",
    "prd_generation": "claude-sonnet-4-5",
    "qa_review": "claude-opus-4-6",
    "test_fix": "claude-opus-4-6",
    "gate_fix": "claude-opus-4-6",
    "reconciliation": "claude-sonnet-4-5"
  },
  "ralph": {
    "tool": "claude",
    "max_iterations_multiplier": 3,
    "stuck_threshold": 3
  },
  "qa": {
    "max_bugfix_cycles": 3
  },
  "gate_checks": {
    "max_fix_cycles": 3,
    "checks": [
      {
        "name": "Docker build",
        "command": "docker compose -f docker-compose.test.yml up -d --build",
        "condition": "command -v docker && test -f docker-compose.yml",
        "required": true
      },
      {
        "name": "Frontend typecheck",
        "command": "cd frontend && npx tsc --noEmit && cd ..",
        "condition": "test -f frontend/tsconfig.json",
        "required": true
      },
      {
        "name": "Backend lint (Ruff)",
        "command": "ruff check services/",
        "condition": "test -d services && command -v ruff",
        "required": true
      },
      {
        "name": "Backend typecheck (mypy)",
        "command": "docker compose -f docker-compose.test.yml run --rm python-tests pytest",
        "condition": "test -d services && command -v mypy",
        "required": false
      },
      {
        "name": "Frontend lint (ESLint)",
        "command": "cd frontend && npx eslint src/ && cd ..",
        "condition": "test -f frontend/eslint.config.js",
        "required": false
      }
    ]
  },
  "env_setup": {
    "source_file": null,
    "setup_function": null,
    "description": "All environment configuration handled via .env file (ports, API keys, Azure credentials)."
  },
  "retry": {
    "max_retries": 3,
    "backoff_seconds": 30
  },
  "cost": {
    "budget_usd": 1000
  },
  "test_infrastructure": {
    "compose_file": "docker-compose.test.yml",
    "services": [
      {
        "name": "postgres",
        "image": "pgvector/pgvector:pg16",
        "port": 5432,
        "environment": {
          "POSTGRES_USER": "testuser",
          "POSTGRES_PASSWORD": "testpass",
          "POSTGRES_DB": "ziqreq_test"
        },
        "readiness": "pg_isready"
      },
      {
        "name": "redis",
        "image": "redis:7-alpine",
        "port": 6379,
        "readiness": "redis-cli ping"
      },
      {
        "name": "rabbitmq",
        "image": "rabbitmq:3-management-alpine",
        "port": 5672,
        "environment": {
          "RABBITMQ_DEFAULT_USER": "testuser",
          "RABBITMQ_DEFAULT_PASS": "testpass"
        },
        "readiness": "rabbitmq-diagnostics check_port_connectivity"
      }
    ],
    "runtimes": [
      {
        "name": "python",
        "base_image": "python:3.12-slim",
        "source_dir": ".",
        "workdir": "/app",
        "dependency_files": ["requirements.txt", "requirements-dev.txt"],
        "install_cmd": "pip install --no-cache-dir -r requirements-dev.txt",
        "test_framework": "pytest",
        "test_cmd": "pytest",
        "ci_flags": "--ci",
        "dockerfile": "infra/docker/Dockerfile.test-python"
      },
      {
        "name": "node",
        "base_image": "node:20-slim",
        "source_dir": "frontend",
        "workdir": "/app",
        "dependency_files": ["package.json", "package-lock.json"],
        "install_cmd": "npm ci",
        "test_framework": "vitest",
        "test_cmd": "npx vitest run",
        "dockerfile": "infra/docker/Dockerfile.test-node"
      }
    ],
    "databases": [
      {
        "service": "postgres",
        "db_name": "ziqreq_test",
        "user": "testuser",
        "password": "testpass"
      },
      {
        "service": "postgres",
        "db_name": "test_ziqreq_test",
        "user": "testuser",
        "password": "testpass",
        "note": "Django test runner creates this via init-test-db.sql"
      }
    ],
    "timeouts": {
      "setup_seconds": 120,
      "build_seconds": 300,
      "test_seconds": 300
    }
  },
  "scaffolding": {
    "enabled": false,
    "project_structure_doc": "docs/02-architecture/project-structure.md",
    "tech_stack_doc": "docs/02-architecture/tech-stack.md",
    "framework_boilerplate": false
  }
}
