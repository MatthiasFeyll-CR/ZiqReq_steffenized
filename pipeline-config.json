  "models": {
    "ralph": "claude-opus-4-6",
    "phase0": "claude-opus-4-6",
    "prd_generation": "claude-sonnet-4-5",
    "qa_review": "claude-opus-4-6",
    "test_fix": "claude-opus-4-6",
    "gate_fix": "claude-opus-4-6",
    "reconciliation": "claude-sonnet-4-5"
  },
  "ralph": {
    "tool": "claude",
    "max_iterations_multiplier": 3,
    "stuck_threshold": 3
  },
  "qa": {
    "max_bugfix_cycles": 3
  },
  "gate_checks": {
    "max_fix_cycles": 3,
    "checks": [
      {
        "name": "Docker build",
        "command": "docker compose build",
        "condition": "command -v docker && test -f docker-compose.yml",
        "required": true
      },
      {
        "name": "Frontend typecheck",
        "command": "cd frontend && npx tsc --noEmit",
        "condition": "test -f frontend/tsconfig.json",
        "required": true
      },
      {
        "name": "Backend lint (Ruff)",
        "command": "ruff check services/",
        "condition": "test -d services && command -v ruff",
        "required": true
      },
      {
        "name": "Backend typecheck (mypy)",
        "command": "mypy services/",
        "condition": "test -d services && command -v mypy",
        "required": false
      },
      {
        "name": "Frontend lint (ESLint)",
        "command": "cd frontend && npx eslint src/",
        "condition": "test -f frontend/eslint.config.js",
        "required": false
      },
      {
        "name": "E2E typecheck",
        "command": "cd e2e && npx tsc --noEmit",
        "condition": "test -f e2e/tsconfig.json",
        "required": true
      },
      {
        "name": "E2E tests",
        "command": "cd e2e && npx playwright test",
        "condition": "test -f e2e/playwright.config.ts",
        "required": true
      }
    ]
  },
  "env_setup": {
    "source_file": null,
    "setup_function": null,
    "description": "All environment configuration handled via .env file (ports, API keys, Azure credentials)."
  },
  "retry": {
    "max_retries": 3,
    "backoff_seconds": 30
  },
  "cost": {
    "budget_usd": 750
  },
  "test_execution": {
    "compose_file": "docker-compose.e2e.yml",
    "test_command": "cd e2e && npx playwright test",
    "test_single_command": "cd e2e && npx playwright test {spec_file}",
    "integration_test_command": "cd e2e && npx playwright test",
    "setup_command": "docker compose -f docker-compose.e2e.yml up -d --build",
    "teardown_command": "docker compose -f docker-compose.e2e.yml down",
    "force_teardown_command": "docker compose -f docker-compose.e2e.yml down -v --remove-orphans",
    "build_command": "docker compose -f docker-compose.e2e.yml build",
    "condition": "command -v docker",
    "setup_timeout_seconds": 180,
    "timeout_seconds": 900,
    "build_timeout_seconds": 300,
    "health_poll": {
      "gateway": "http://localhost:8000/api/auth/dev-users",
      "frontend": "http://localhost:5173",
      "poll_interval_ms": 2000,
      "max_wait_ms": 120000
    },
    "services": [
      {
        "name": "gateway",
        "type": "http",
        "url": "http://localhost:8000/api/auth/dev-users",
        "startup_timeout": 120
      },
      {
        "name": "frontend",
        "type": "http",
        "url": "http://localhost:5173",
        "startup_timeout": 120
      }
    ]
  },
  "scaffolding": {
    "enabled": false,
    "project_structure_doc": "docs/02-architecture/project-structure.md",
    "tech_stack_doc": "docs/02-architecture/tech-stack.md",
    "framework_boilerplate": false
  }
}
