      ]
    },
    {
      "id": 10,
      "slug": "review",
      "name": "Review Workflow",
      "stories": 10,
      "dependencies": [
        9
      ]
    },
    {
      "id": 11,
      "slug": "collaboration",
      "name": "Collaboration & Sharing",
      "stories": 9,
      "dependencies": [
