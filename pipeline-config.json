{
  "$schema": "pipeline-config-schema.json",
  "version": "1.0",

  "project": {
    "name": "ZiqReq",
    "description": "Collaborative brainstorming platform with AI-powered facilitation, digital boards, BRD generation, and review workflows"
  },

  "paths": {
    "docs_dir": "docs",
    "tasks_dir": "tasks",
    "scripts_dir": ".ralph",
    "skills_dir": "~/.claude/skills",
    "qa_dir": "docs/08-qa",
    "reconciliation_dir": "docs/05-reconciliation",
    "milestones_dir": "docs/05-milestones",
    "archive_dir": ".ralph/archive"
  },

  "milestones": [
    {
      "id": 1,
      "slug": "foundation",
      "name": "Foundation",
      "stories": 10,
      "dependencies": []
    },
    {
      "id": 2,
      "slug": "shell-landing",
      "name": "Shell + Landing Page",
      "stories": 9,
      "dependencies": [1]
    },
    {
      "id": 3,
      "slug": "workspace-chat-realtime",
      "name": "Workspace + Chat + Real-Time",
      "stories": 10,
      "dependencies": [2]
    },
    {
      "id": 4,
      "slug": "digital-board",
      "name": "Digital Board",
      "stories": 9,
      "dependencies": [3]
    },
    {
      "id": 5,
      "slug": "ai-facilitation",
      "name": "AI Facilitation",
      "stories": 9,
      "dependencies": [4]
    },
    {
      "id": 6,
      "slug": "ai-context-knowledge",
      "name": "AI Context & Knowledge",
      "stories": 7,
      "dependencies": [5]
    },
    {
      "id": 7,
      "slug": "review-brd",
      "name": "Review & BRD Generation",
      "stories": 10,
      "dependencies": [5]
    },
    {
      "id": 8,
      "slug": "review-workflow",
      "name": "Review Workflow + Review Page",
      "stories": 8,
      "dependencies": [7]
    },
    {
      "id": 9,
      "slug": "collaboration-notifications",
      "name": "Collaboration + Notifications",
      "stories": 10,
      "dependencies": [3, 8]
    },
    {
      "id": 10,
      "slug": "similarity-merge",
      "name": "Similarity & Merge",
      "stories": 9,
      "dependencies": [5, 6, 9]
    },
    {
      "id": 11,
      "slug": "admin-monitoring",
      "name": "Admin Panel + Monitoring",
      "stories": 8,
      "dependencies": [6]
    }
  ],

  "models": {
    "ralph": "",
    "prd_generation": "claude-sonnet-4-6",
    "qa_review": "claude-sonnet-4-6",
    "test_fix": "",
    "gate_fix": "",
    "reconciliation": "claude-sonnet-4-6"
  },

  "ralph": {
    "tool": "claude",
    "max_iterations_multiplier": 3,
    "stuck_threshold": 3
  },

  "qa": {
    "max_bugfix_cycles": 3
  },

  "gate_checks": {
    "max_fix_cycles": 3,
    "checks": [
      {
        "name": "Docker compose build (dev)",
        "command": "docker compose -f infra/docker/docker-compose.yml build",
        "condition": "command -v docker && test -f infra/docker/docker-compose.yml",
        "required": true
      },
      {
        "name": "TypeScript typecheck",
        "command": "docker compose -f docker-compose.test.yml run --rm test-node npx tsc --noEmit",
        "condition": "test -f docker-compose.test.yml && test -f frontend/tsconfig.json",
        "required": true
      },
      {
        "name": "Python lint (Ruff)",
        "command": "docker compose -f docker-compose.test.yml run --rm test-python ruff check services/",
        "condition": "test -f docker-compose.test.yml && test -d services",
        "required": false
      },
      {
        "name": "Frontend lint (ESLint)",
        "command": "docker compose -f docker-compose.test.yml run --rm test-node npx eslint src/",
        "condition": "test -f docker-compose.test.yml && test -f frontend/eslint.config.js",
        "required": false
      },
      {
        "name": "Python typecheck (mypy)",
        "command": "docker compose -f docker-compose.test.yml run --rm test-python mypy services/",
        "condition": "test -f docker-compose.test.yml && command -v docker",
        "required": false
      }
    ]
  },

  "env_setup": {
    "source_file": "ralph.sh",
    "setup_function": "claude-azure",
    "description": "Sources ralph.sh which loads .ai.env and configures Azure AI Foundry endpoint for Claude. Project .env is read by Docker Compose automatically."
  },

  "test_execution": {
    "test_command": "docker compose -f docker-compose.test.yml run --rm test-python pytest && docker compose -f docker-compose.test.yml run --rm test-node npx vitest run",
    "integration_test_command": null,
    "timeout_seconds": 600,
    "max_fix_cycles": 5,
    "condition": "test -f docker-compose.test.yml",
    "build_command": "docker compose -f docker-compose.test.yml build --no-cache test-python test-node",
    "build_timeout_seconds": 600,
    "setup_command": "docker compose -f docker-compose.test.yml down --volumes --remove-orphans && docker compose -f docker-compose.test.yml up -d postgresql redis rabbitmq && for i in $(seq 1 30); do pg_isready -h localhost -p 5432 -U ziqreq -q 2>/dev/null && break; sleep 2; done && for i in $(seq 1 15); do bash -c 'echo > /dev/tcp/localhost/6379' 2>/dev/null && break; sleep 2; done && for i in $(seq 1 15); do bash -c 'echo > /dev/tcp/localhost/5672' 2>/dev/null && break; sleep 2; done",
    "teardown_command": "docker compose -f docker-compose.test.yml down --volumes --remove-orphans",
    "force_teardown_command": "docker compose -f docker-compose.test.yml kill && docker compose -f docker-compose.test.yml down --volumes --remove-orphans --timeout 5; docker compose -f docker-compose.test.yml rm -f -v",
    "setup_timeout_seconds": 120,

    "services": [
      {"name": "postgresql", "type": "tcp", "host": "localhost", "port": 5432, "startup_timeout": 30},
      {"name": "redis", "type": "tcp", "host": "localhost", "port": 6379, "startup_timeout": 15},
      {"name": "rabbitmq", "type": "tcp", "host": "localhost", "port": 5672, "startup_timeout": 30}
    ],

    "tier1": {
      "compose_file": "docker-compose.test.yml",
      "teardown_command": "docker compose -f docker-compose.test.yml down --volumes --remove-orphans",
      "setup_command": "echo 'No dependency services needed — backend tests use SQLite in-memory'",
      "setup_timeout_seconds": 30,
      "build_timeout_seconds": 600,
      "image_hash_file": ".test-image-hashes",
      "environments": [
        {
          "name": "python",
          "service": "test-python",
          "test_command": "docker compose -f docker-compose.test.yml run --rm test-python pytest",
          "build_command": "docker compose -f docker-compose.test.yml build --no-cache test-python",
          "rebuild_trigger_files": ["services/gateway/requirements.txt", "services/core/requirements.txt", "services/ai/requirements.txt", "services/notification/requirements.txt", "services/pdf/requirements.txt", "pyproject.toml", "docker-compose.test.yml"],
          "condition": "test -d services",
          "timeout_seconds": 300
        },
        {
          "name": "node",
          "service": "test-node",
          "test_command": "docker compose -f docker-compose.test.yml run --rm test-node npx vitest run",
          "build_command": "docker compose -f docker-compose.test.yml build --no-cache test-node",
          "rebuild_trigger_files": ["frontend/package.json", "frontend/package-lock.json", "docker-compose.test.yml"],
          "condition": "test -f frontend/package.json",
          "timeout_seconds": 300
        }
      ]
    }
  },

  "retry": {
    "max_retries": 3,
    "backoff_seconds": 30
  }
}
