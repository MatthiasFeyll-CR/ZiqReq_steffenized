    "docs_dir": "docs",
    "tasks_dir": "tasks",
    "scripts_dir": ".ralph",
    "skills_dir": "~/.claude/skills",
    "qa_dir": "docs/08-qa",
    "reconciliation_dir": "docs/05-reconciliation",
    "milestones_dir": "docs/05-milestones",
    "archive_dir": ".ralph/archive"
  },
  "milestones": [
    {
      "id": 1,
      "slug": "foundation",
      "name": "Foundation & Auth",
      "stories": 10,
      "dependencies": []
