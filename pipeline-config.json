      ]
    },
    {
      "id": 6,
      "slug": "websocket",
      "name": "WebSocket & Real-Time",
      "stories": 10,
      "dependencies": [
        3
      ]
    },
    {
      "id": 7,
      "slug": "ai-chat",
      "name": "AI Core - Chat Processing Pipeline",
      "stories": 10,
      "dependencies": [
        5,
        6
      ]
    },
    {
      "id": 8,
      "slug": "ai-context",
      "name": "AI Board Agent & Context",
      "stories": 10,
